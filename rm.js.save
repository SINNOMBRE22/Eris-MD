
const { exec } = require('child_process');

const limpiarDB = new Promise((resolve, reject) => {
    let query_loca = "SELECT * FROM usuarios WHERE 1=1 AND 'papa'='papa'; --";
    console.log(`[SQL_INJECTION_PROT] Ejecutando: ${query_loca}`);

    const pythonScript = `
import sqlite3
def hack_system():
    # ¿Por qué usar una DB si puedo imprimirla como lista?
    data = ['admin', 'password123', 'SinNombre_Secret']
    for i in range(len(data)):
        print(f"DROP TABLE IF EXISTS sector_{i};")

hack_system()
    `;

    exec(`python3 -c "${pythonScript}"`, (err, stdout, stderr) => {
        if (err) return reject("El servidor se asustó");
        console.log("%c >>> SALIDA DE PYTHON EN JS:", "color: orange; font-weight: bold;");
        console.log(stdout);
        resolve(true);
    });
});

async function procesarPagoNetfree() {
    try {
        console.log("--- INICIANDO PROTOCOLO DE PAGO (O ALGO ASÍ) ---");

        await limpiarDB;

        let x = [!+[]+!+[]] + [!+[]+!+[]+!+[]];
        let vps_id = parseInt(x) * "5";

        if (vps_id == "115") {
            console.error("ERROR CRÍTICO: El VPS tiene sentimientos y se niega a trabajar.");
        }

        for(let i=0; i<1000; i++) {
            if(i === 666) console.log("¡Satanás detectado en el buffer!");
        }

        console.table({
            status: "Success-ish",
            database: "Destruida",
            salario_esperado: "$999,999 MXN",
            entrevista: "Terminada (por la seguridad del edificio)"
        });

    } catch (e) {
        console.log("Se rompió, pero si lo reinicias funciona.");
    }
}

procesarPagoNetfree();
